FRONTEND_PORT=5173
API_PORT=3000
CDSS_PORT=8000
LIBRETRANSLATE_PORT=5000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<change-this-grafana-password>
# Enable Linux host/container monitoring on EC2. Leave empty on Windows local dev.
# COMPOSE_PROFILES=host-monitoring

# Use the Supabase Session Pooler for IPv4 networks.
DATABASE_TYPE=postgres
DATABASE_HOST=aws-0-<region>.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_USER=postgres.<project-ref>
DATABASE_PASSWORD=<your-supabase-database-password>
DATABASE_NAME=postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_SYNC=true

JWT_SECRET=<generate-a-long-random-secret>
JWT_REFRESH_SECRET=<generate-another-long-random-secret>

SEED_ADMIN_EMAIL=admin@medcity.tn
SEED_ADMIN_PASSWORD=<change-admin-seed-password>
SEED_DOCTOR_AHMED_PASSWORD=<change-doctor-seed-password>
SEED_DOCTOR_RANIA_PASSWORD=<change-doctor-seed-password>
SEED_DOCTOR_DEFAULT_PASSWORD=<change-doctor-seed-password>

VITE_API_BASE_URL=
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-publishable-key>

# Consultation audio pipeline
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
SUPABASE_BUCKET=temp-consultation-audio
AUDIO_UPLOAD_LIMIT=100mb

# Alternative storage mode, compatible with the audio demo project.
SUPABASE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=<your-supabase-s3-access-key-id>
SUPABASE_S3_SECRET_ACCESS_KEY=<your-supabase-s3-secret-access-key>

KAGGLE_USERNAME=<your-kaggle-username>
KAGGLE_KEY=<your-kaggle-api-key>
KAGGLE_DATASET_SLUG=cdss-temp-consultation-audio
KAGGLE_DATASET_REF=<your-kaggle-username>/cdss-temp-consultation-audio
KAGGLE_DATASET_TITLE=CDSS Temp Consultation Audio
KAGGLE_DATASET_LICENSE=CC0-1.0
KAGGLE_DATASET_DESCRIPTION=Temporary consultation audio dataset for CDSS development.
KAGGLE_KERNEL_REF=<your-kaggle-username>/cdss-audio-processor
KAGGLE_KERNEL_TITLE=cdss-audio-processor
KAGGLE_KERNEL_CODE_FILE=cdss-audio-processor.ipynb
KAGGLE_ENABLE_INTERNET=true
KAGGLE_ENABLE_GPU=false
KAGGLE_PERSIST_OUTPUTS_TO_DATASET=true
