FRONTEND_PORT=5173
API_PORT=3000
CDSS_PORT=8000
LIBRETRANSLATE_PORT=5000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<change-this-grafana-password>
GRAFANA_PUBLIC_URL=http://localhost:5173/grafana/
GRAFANA_SERVE_FROM_SUB_PATH=true
# Enable Linux host/container monitoring on EC2. Leave empty on Windows local dev.
# COMPOSE_PROFILES=host-monitoring

# Use the Supabase Session Pooler for IPv4 networks.
DATABASE_TYPE=postgres
DATABASE_HOST=aws-0-<region>.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_USER=postgres.<project-ref>
DATABASE_PASSWORD=<your-supabase-database-password>
DATABASE_NAME=postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_SYNC=true

JWT_SECRET=<generate-a-long-random-secret>
JWT_REFRESH_SECRET=<generate-another-long-random-secret>

EMAIL_ENABLED=true
FRONTEND_PUBLIC_URL=http://localhost:5173
RESEND_API_KEY=<your-resend-api-key>
RESEND_FROM=MedCity Connect <onboarding@resend.dev>
RESEND_TIMEOUT_MS=10000
CONTACT_NOTIFICATION_TO=contact@medcity.tn
NEWSLETTER_NOTIFICATION_TO=contact@medcity.tn
NEWSLETTER_CONFIRMATION_ENABLED=true

# Opt-in only: real external integration tests. Never enable in normal CI.
RUN_EXTERNAL_INTEGRATION_TESTS=false
EXTERNAL_TEST_TARGET=all
EXTERNAL_TEST_EMAIL=triguiislem1@gmail.com
# upload-status: real Supabase upload + real Kaggle status
# start-processing: also downloads from Supabase, versions Kaggle dataset, pushes kernel
# full: also waits for Kaggle completion and fetches output
EXTERNAL_AUDIO_MODE=upload-status
EXTERNAL_KAGGLE_WAIT_TIMEOUT_MS=900000
EXTERNAL_KAGGLE_WAIT_INTERVAL_MS=30000

SEED_ADMIN_EMAIL=admin@medcity.tn
SEED_ADMIN_PASSWORD=<change-admin-seed-password>
SEED_DOCTOR_AHMED_PASSWORD=<change-doctor-seed-password>
SEED_DOCTOR_RANIA_PASSWORD=<change-doctor-seed-password>
SEED_DOCTOR_DEFAULT_PASSWORD=<change-doctor-seed-password>

VITE_API_BASE_URL=
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-publishable-key>
# Admin dashboard external link to Grafana. Use a protected public/reverse-proxy URL on EC2.
VITE_GRAFANA_URL=http://localhost:5173/grafana/d/medcity-overview/medcity-overview?orgId=1&refresh=30s

# CDSS FastAPI adapter. Use direct when FastAPI is reachable, kaggle when
# FastAPI+Qwen run inside the offline notebook worker described in the zip.
CDSS_EXECUTION_MODE=direct
CDSS_API_BASE_URL=http://cdss:8000
CDSS_API_TIMEOUT_MS=1800000
CDSS_KAGGLE_NOTEBOOK_TEMPLATE_PATH=./kaggle/notebook016167db17_worker_test_ready.ipynb
CDSS_KAGGLE_KERNEL_REF_MODE=shared
CDSS_KAGGLE_KERNEL_REF=<your-kaggle-username>/cdss-prescription-worker
CDSS_KAGGLE_KERNEL_TITLE=CDSS Prescription Worker
CDSS_KAGGLE_KERNEL_SLUG_PREFIX=cdss-worker
CDSS_KAGGLE_ACCELERATOR=NvidiaTeslaT4
CDSS_KAGGLE_DATASET_SOURCES=triguiislem/cdss-final-runtime-databases,islemtrigui6/tn-med-db-v1,islemtrigui6/hetionet-primekg-kuzu-database
CDSS_KAGGLE_RUNTIME_DIR=.runtime/cdss-kaggle

# Consultation audio pipeline
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
SUPABASE_BUCKET=temp-consultation-audio
AUDIO_UPLOAD_LIMIT=100mb
TN_MED_SQLITE_PATH=/app/data/tn-med-db-v1/database/TN_Med.db
# Optional for quick local checks. Leave empty to import the full 6093-row dataset.
TN_MED_IMPORT_LIMIT=

# Alternative storage mode, compatible with the audio demo project.
SUPABASE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=<your-supabase-s3-access-key-id>
SUPABASE_S3_SECRET_ACCESS_KEY=<your-supabase-s3-secret-access-key>

KAGGLE_USERNAME=<your-kaggle-username>
KAGGLE_KEY=<your-kaggle-api-key>
KAGGLE_DATASET_SLUG=cdss-temp-consultation-audio
KAGGLE_DATASET_REF=<your-kaggle-username>/cdss-temp-consultation-audio
KAGGLE_DATASET_TITLE=CDSS Temp Consultation Audio
KAGGLE_DATASET_LICENSE=CC0-1.0
KAGGLE_DATASET_DESCRIPTION=Temporary consultation audio dataset for CDSS development.
KAGGLE_KERNEL_REF=<your-kaggle-username>/cdss-audio-processor
KAGGLE_KERNEL_TITLE=cdss-audio-processor
KAGGLE_KERNEL_CODE_FILE=cdss-audio-processor.ipynb
KAGGLE_ENABLE_INTERNET=true
KAGGLE_ENABLE_GPU=false
KAGGLE_PERSIST_OUTPUTS_TO_DATASET=true
