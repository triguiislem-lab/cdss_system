APP_NAME=Clinical Prescription System
APP_ENV=local
API_PREFIX=/v1
LOG_LEVEL=INFO
KG_BACKEND=csv
KG_CATALOG_PATH=data/runtime/tn_master_kg_edges.csv
VECTOR_BACKEND=final_release_jsonl
VECTOR_CORPUS_PATH=data/runtime/tn_prescription_evidence_corpus.jsonl
LOCAL_FORMULARY_BACKEND=csv
LOCAL_FORMULARY_CATALOG_PATH=data/runtime/tn_master_amm_catalog.csv
GENERATION_BACKEND=openai_compatible
GENERATION_MODEL=Qwen3-32B
GENERATION_BASE_URL=http://127.0.0.1:8000/v1
GENERATION_TEMPERATURE=0.2
GENERATION_MAX_OUTPUT_TOKENS=400
LOCALIZATION_MARKET=TN
AUDIT_BACKEND=file
AUDIT_DIR=data/audit

# KG backup Hetionet/PrimeKG support-only retrieval
KG_BACKUP_ENABLED=false
KG_BACKUP_BACKEND=kuzu
KG_BACKUP_KUZU_DB_PATH=
HETIONET_PRIMEKG_KUZU_DB_PATH=
KG_BACKUP_SCORE_MULTIPLIER=0.92
KG_BACKUP_MIN_SUPPORT_FACTS=3
KG_BACKUP_RESERVED_LIMIT=8
KG_SOURCE_MODE=primary_plus_backups
VECTOR_FALLBACK_BACKEND=
VECTOR_FALLBACK_FAISS_INDEX_PATH=
VECTOR_FALLBACK_FAISS_METADATA_PATH=
VECTOR_PICKLE_TEXTS_PATH=

# Model Configurations (NEW)
# Vector Retrieval - BGE-M3 (multilingual, strong medical terminology understanding)
VECTOR_EMBEDDING_MODEL=BAAI/bge-m3

# Reranking Models
# Main: BGE Reranker v2 M3 (multilingual, cross-encoder for relevance scoring)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Fallback: ms-marco-MiniLM-L6-v2 (English-only, lightweight)
RERANKER_FALLBACK_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2

# Translation - NLLB-200 Distilled 1.3B (200+ languages, lightweight distilled version)
TRANSLATION_MODEL=facebook/nllb-200-distilled-1.3B

# Deduplication - paraphrase-multilingual-MiniLM-L12-v2 (fast multilingual similarity)
DEDUPLICATION_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# LLM - Qwen3-32B (clinical understanding, multilingual)
LLM_MODEL=Qwen3-32B

# V4.18-V4.23 staged activation flags
SAFETY_POLICY_MODE=enforce
CLINICAL_ACTION_ENABLED=true
MEDICAL_ORDER_EXTRACTION_MODE=enforce
POST_GENERATION_VALIDATOR_MODE=enforce
MULTILINGUAL_RETRIEVAL_ENABLED=false
MULTILINGUAL_TRANSLATION_ENABLED=false
MULTILINGUAL_RERANKER_ENABLED=false
PROFESSIONAL_VALIDATION_ENABLED=true
ALLOW_ONLINE_MODEL_DOWNLOAD=false

ALLOW_STUB_FALLBACKS=false
FAIL_CLOSED_EVIDENCE_FILTERS=true
KG_CURATED_FALLBACK_ENABLED=false
DEDUPLICATION_ENABLED=false
STRICT_RUNTIME_READINESS=true
FEEDBACK_DIR=data/feedback

FEEDBACK_BACKEND=sqlite
# MEDIQA-OE style Qwen structured medical-order/event extraction
MEDICAL_ORDER_LLM_EXTRACTION_ENABLED=true
MEDICAL_ORDER_LLM_EXTRACTION_MODE=assist
MEDICAL_ORDER_LLM_EXTRACTION_POLICY=selective
MEDICAL_ORDER_LLM_EXTRACTION_TEMPERATURE=0.0
MEDICAL_ORDER_LLM_EXTRACTION_MAX_OUTPUT_TOKENS=1800
MEDICAL_ORDER_LLM_EXTRACTION_CONFIDENCE_THRESHOLD=0.60
CDSS_KUZU_EXTRACT_DIR=
VECTOR_FALLBACK_FAISS_STATS_PATH=
# TN Med DB v1 structured enrichment layer
TN_MED_ENABLED=false
TN_MED_DATA_ROOT=/kaggle/input/datasets/islemtrigui6/tn-med-db-v1
TN_MED_DB_PATH=/kaggle/input/datasets/islemtrigui6/tn-med-db-v1/database/TN_Med.db
TN_MED_REQUIRED_FOR_READINESS=false
TN_MED_TOP_K=4

