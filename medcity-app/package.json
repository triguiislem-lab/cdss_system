{
  "name": "medcity-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --preserve-symlinks --preserve-symlinks-main node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node --preserve-symlinks --preserve-symlinks-main node_modules/vite/bin/vite.js build",
    "serve": "node --preserve-symlinks --preserve-symlinks-main node_modules/vite/bin/vite.js preview --host 0.0.0.0",
    "typecheck": "node --preserve-symlinks --preserve-symlinks-main node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "backend:build": "npm --prefix backend_template run build",
    "backend:dev": "npm --prefix backend_template run start:dev",
    "backend:seed": "npm --prefix backend_template run seed",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
