NODE_ENV=development
PORT=3000
API_PREFIX=api

# Default local database: data/medcity.sqlite
DATABASE_TYPE=sqlite
SQLITE_DATABASE=./data/medcity.sqlite
DATABASE_SYNC=true

# PostgreSQL settings, used only when DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=medcity_connect
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Supabase direct Postgres example:
# DATABASE_TYPE=postgres
# DATABASE_HOST=db.<project-ref>.supabase.co
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=<your-database-password>
# DATABASE_NAME=postgres
# DATABASE_SSL=true

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=7d

SEED_ADMIN_EMAIL=admin@medcity.test
SEED_ADMIN_PASSWORD=Admin123!

# LibreTranslate runs as a separate local Python service.
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=
TRANSLATION_SOURCE_LANG=fr
TRANSLATION_TARGET_LANGS=en,ar
TRANSLATION_TIMEOUT_MS=15000
