NODE_ENV=development
PORT=3000
API_PREFIX=api

# Default local database: data/medcity.sqlite
DATABASE_TYPE=sqlite
SQLITE_DATABASE=./data/medcity.sqlite
DATABASE_SYNC=true

# PostgreSQL settings, used only when DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=medcity_connect
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Supabase Session Pooler example, recommended for IPv4 networks:
# DATABASE_TYPE=postgres
# DATABASE_HOST=aws-0-<region>.pooler.supabase.com
# DATABASE_PORT=5432
# DATABASE_USER=postgres.<project-ref>
# DATABASE_PASSWORD=<your-database-password>
# DATABASE_NAME=postgres
# DATABASE_SSL=true

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=7d

EMAIL_ENABLED=true
RESEND_API_KEY=
RESEND_FROM=MedCity Connect <onboarding@resend.dev>
RESEND_TIMEOUT_MS=10000
CONTACT_NOTIFICATION_TO=contact@medcity.tn
NEWSLETTER_NOTIFICATION_TO=contact@medcity.tn
NEWSLETTER_CONFIRMATION_ENABLED=true

# Opt-in only: real external integration tests. Never enable in normal CI.
RUN_EXTERNAL_INTEGRATION_TESTS=false
EXTERNAL_TEST_TARGET=all
EXTERNAL_TEST_EMAIL=triguiislem1@gmail.com
# upload-status: real Supabase upload + real Kaggle status
# start-processing: also downloads from Supabase, versions Kaggle dataset, pushes kernel
# full: also waits for Kaggle completion and fetches output
EXTERNAL_AUDIO_MODE=upload-status
EXTERNAL_KAGGLE_WAIT_TIMEOUT_MS=900000
EXTERNAL_KAGGLE_WAIT_INTERVAL_MS=30000

SEED_ADMIN_EMAIL=admin@medcity.test
SEED_ADMIN_PASSWORD=<local-admin-password>
SEED_DOCTOR_AHMED_PASSWORD=<local-doctor-password>
SEED_DOCTOR_RANIA_PASSWORD=<local-doctor-password>

# LibreTranslate runs as a separate local Python service.
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=
TRANSLATION_SOURCE_LANG=fr
TRANSLATION_TARGET_LANGS=en,ar
TRANSLATION_TIMEOUT_MS=15000

# CDSS FastAPI adapter. Source-of-truth contract comes from
# cdss_nestjs_fastapi_complete_adapter_v2_with_kaggle_docs.zip.
# direct: NestJS calls a reachable FastAPI runtime.
# kaggle: NestJS submits an offline Kaggle notebook worker job.
CDSS_EXECUTION_MODE=direct
CDSS_API_BASE_URL=http://localhost:8000
CDSS_API_TIMEOUT_MS=1800000
CDSS_KAGGLE_NOTEBOOK_TEMPLATE_PATH=./kaggle/notebook016167db17_worker_test_ready.ipynb
CDSS_KAGGLE_KERNEL_REF_MODE=shared
CDSS_KAGGLE_KERNEL_REF=
CDSS_KAGGLE_KERNEL_TITLE=CDSS Prescription Worker
CDSS_KAGGLE_KERNEL_SLUG_PREFIX=cdss-worker
CDSS_KAGGLE_ACCELERATOR=NvidiaTeslaT4
CDSS_KAGGLE_DATASET_SOURCES=triguiislem/cdss-final-runtime-databases,islemtrigui6/tn-med-db-v1,islemtrigui6/hetionet-primekg-kuzu-database
CDSS_KAGGLE_RUNTIME_DIR=.runtime/cdss-kaggle

# Audio consultation pipeline: NestJS uploads raw recordings to Supabase Storage,
# prepares a private Kaggle dataset, runs the Kaggle processor, then stores the
# transcript/result back on the consultation row.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=temp-consultation-audio
AUDIO_UPLOAD_LIMIT=100mb
TN_MED_SQLITE_PATH=./data/tn-med-db-v1/database/TN_Med.db
# Optional for quick local checks. Leave empty to import the full 6093-row dataset.
TN_MED_IMPORT_LIMIT=
DELETE_SUPABASE_AFTER_KAGGLE=false

# Alternative when the working demo uses Supabase Storage through S3 keys.
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=

KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_DATASET_SLUG=cdss-temp-consultation-audio
KAGGLE_DATASET_REF=
KAGGLE_DATASET_TITLE=CDSS Temp Consultation Audio
KAGGLE_DATASET_LICENSE=CC0-1.0
KAGGLE_DATASET_DESCRIPTION=Temporary consultation audio dataset for CDSS development.
KAGGLE_SKIP_EXISTING_DATASETS=false
KAGGLE_DELETE_OLD_VERSIONS=false
KAGGLE_KERNEL_REF=
KAGGLE_KERNEL_TITLE=cdss-audio-processor
KAGGLE_KERNEL_TYPE=notebook
KAGGLE_KERNEL_CODE_FILE=cdss-audio-processor.ipynb
KAGGLE_ENABLE_INTERNET=true
KAGGLE_ENABLE_GPU=false
KAGGLE_ACCELERATOR=
KAGGLE_EXTRA_DATASET_SOURCES=
KAGGLE_MODEL_SOURCES=
KAGGLE_PERSIST_OUTPUTS_TO_DATASET=true
KAGGLE_DATASET_READY_TIMEOUT_MS=180000
KAGGLE_DATASET_READY_INTERVAL_MS=10000
